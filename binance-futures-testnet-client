@dataclass
class OrderResult:
"""Dataclass to hold order results"""
success: bool
order_id: Optional[str] = None
error: Optional[str] = None
data: Optional[Dict[str, Any]] = None

class BinanceFuturesTestnetClient:
"""
Binance Futures Testnet Client for USDT-Margined contracts
"""

TESTNET_URL = "https://testnet.binancefuture.com"  
BASE_URL = f"{TESTNET_URL}/fapi"  
  
def __init__(self, api_key: str, api_secret: str):  
    """  
    Initialize the client with API credentials  
      
    Args:  
        api_key: Binance Testnet API Key  
        api_secret: Binance Testnet API Secret  
    """  
    if not api_key or not api_secret:  
        raise ValueError("API key and secret are required")  
      
    self.api_key = api_key  
    self.api_secret = api_secret  
    self.client = Client(api_key, api_secret, testnet=True)  
    self.session = requests.Session()  
    self.session.headers.update({  
        'X-MBX-APIKEY': api_key  
    })  
      
    # Test connection  
    self._test_connection()  
  
def _test_connection(self):  
    """Test API connection"""  
    try:  
        account = self.client.futures_account()  
        logger.info("✅ Connected to Binance Futures Testnet successfully")  
        logger.info(f"Account balance: {account.get('totalWalletBalance', 'N/A')} USDT")  
    except Exception as e:  
        logger.error(f"❌ Failed to connect to Binance Testnet: {e}")  
        raise  
  
def _generate_signature(self, query_string: str) -> str:  
    """Generate HMAC SHA256 signature"""  
    return hmac.new(  
        self.api_secret.encode('utf-8'),  
        query_string.encode('utf-8'),  
        hashlib.sha256  
    ).hexdigest()  
  
def get_account_balance(self) -> Dict[str, Any]:  
    """Get futures account balance"""  
    try:  
        balance = self.client.futures_account_balance()  
        logger.info("Retrieved account balance successfully")  
        return {"success": True, "data": balance}  
    except Exception as e:  
        logger.error(f"Failed to get account balance: {e}")  
        return {"success": False, "error": str(e)}  
  
def get_account_info(self) -> Dict[str, Any]:  
    """Get complete account information"""  
    try:  
        info = self.client.futures_account()  
        logger.info("Retrieved account info successfully")  
        return {"success": True, "data": info}  
    except Exception as e:  
        logger.error(f"Failed to get account info: {e}")  
        return {"success": False, "error": str(e)}  
  
def get_symbol_info(self, symbol: str) -> Dict[str, Any]:  
    """Get symbol trading rules"""  
    try:  
        info = self.client.futures_exchange_info()  
        symbol_info = next((s for s in info['symbols'] if s['symbol'] == symbol), None)  
        if symbol_info:  
            logger.info(f"Retrieved info for {symbol}")  
            return {"success": True, "data": symbol_info}  
        else:  
            return {"success": False, "error": f"Symbol {symbol} not found"}  
    except Exception as e:  
        logger.error(f"Failed to get symbol info for {symbol}: {e}")  
        return {"success": False, "error": str(e)}  
  
def place_market_order(  
    self,   
    symbol: str,   
    side: str,   
    quantity: float  
) -> OrderResult:  
    """  
    Place a market order  
      
    Args:  
        symbol: Trading pair (e.g., 'BTCUSDT')  
        side: 'BUY' or 'SELL'  
        quantity: Order quantity  
    """  
    try:  
        # Validate symbol info  
        symbol_info = self.get_symbol_info(symbol)  
        if not symbol_info["success"]:  
            return OrderResult(success=False, error=symbol_info["error"])  
          
        # Adjust quantity to meet stepSize  
        step_size = float(next(  
            f['stepSize'] for f in symbol_info['data']['filters']   
            if f['filterType'] == 'LOT_SIZE'  
        ))  
        quantity = round(quantity / step_size) * step_size  
          
        order = self.client.futures_create_order(  
            symbol=symbol,  
            side=side,  
            type=ORDER_TYPE_MARKET,  
            quantity=quantity  
        )  
          
        logger.info(f"✅ Market {side} order placed: {quantity} {symbol} | Order ID: {order['orderId']}")  
        return OrderResult(  
            success=True,   
            order_id=str(order['orderId']),   
            data=order  
        )  
          
    except Exception as e:  
        error_msg = f"Failed to place market order {side} {quantity} {symbol}: {e}"  
        logger.error(error_msg)  
        return OrderResult(success=False, error=error_msg)  
  
def place_limit_order(  
    self,  
    symbol: str,  
    side: str,  
    quantity: float,  
    price: float,  
    time_in_force: str = TIME_IN_FORCE_GTC  
) -> OrderResult:  
    """  
    Place a limit order  
      
    Args:  
        symbol: Trading pair  
        side: 'BUY' or 'SELL'  
        quantity: Order quantity  
        price: Limit price  
        time_in_force: GTC, IOC, FOK  
    """  
    try:  
        symbol_info = self.get_symbol_info(symbol)  
        if not symbol_info["success"]:  
            return OrderResult(success=False, error=symbol_info["error"])  
          
        # Adjust quantity and price to meet requirements  
        step_size = float(next(  
            f['stepSize'] for f in symbol_info['data']['filters']   
            if f['filterType'] == 'LOT_SIZE'  
        ))  
        tick_size = float(next(  
            f['tickSize'] for f in symbol_info['data']['filters']   
            if f['filterType'] == 'PRICE_FILTER'  
        ))  
          
        quantity = round(quantity / step_size) * step_size  
        price = round(price / tick_size) * tick_size  
          
        order = self.client.futures_create_order(  
            symbol=symbol,  
            side=side,  
            type=ORDER_TYPE_LIMIT,  
            timeInForce=time_in_force,  
            quantity=quantity,  
            price=price  
        )  
          
        logger.info(f"✅ Limit {side} order placed: {quantity} {symbol} @ {price} | Order ID: {order['orderId']}")  
        return OrderResult(  
            success=True,  
            order_id=str(order['orderId']),  
            data=order  
        )  
          
    except Exception as e:  
        error_msg = f"Failed to place limit order {side} {quantity} {symbol} @ {price}: {e}"  
        logger.error(error_msg)  
        return OrderResult(success=False, error=error_msg)  
  
def cancel_order(self, symbol: str, order_id: str) -> OrderResult:  
    """Cancel an open order"""  
    try:  
        result = self.client.futures_cancel_order(symbol=symbol, orderId=order_id)  
        logger.info(f"✅ Order {order_id} cancelled for {symbol}")  
        return OrderResult(success=True, order_id=order_id, data=result)  
    except Exception as e:  
        error_msg = f"Failed to cancel order {order_id} for {symbol}: {e}"  
        logger.error(error_msg)  
        return OrderResult(success=False, error=error_msg)  
  
def get_open_orders(self, symbol: Optional[str] = None) -> Dict[str, Any]:  
    """Get all open orders"""  
    try:  
        if symbol:  
            orders = self.client.futures_get_open_orders(symbol=symbol)  
        else:  
            orders = self.client.futures_get_open_orders()  
        logger.info(f"Retrieved {len(orders)} open orders")  
        return {"success": True, "data": orders}  
    except Exception as e:  
        logger.error(f"Failed to get open orders: {e}")  
        return {"success": False, "error": str(e)}

def load_config(config_path: str = "config.json") -> Dict[str, str]:
"""Load API credentials from config file"""
try:
with open(config_path, 'r') as f:
config = json.load(f)
return config
except FileNotFoundError:
logger.error(f"Config file {config_path} not found. Please create it with your API credentials.")
raise
except json.JSONDecodeError:
logger.error(f"Invalid JSON in {config_path}")
raise

